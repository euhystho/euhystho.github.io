---
import { SITE_DESCRIPTION, SITE_TITLE } from "../utils/consts.ts";
import FeaturedCard from "src/components/blog/featuredCard.astro";
import MainLayout from "src/components/layouts/MainLayout.astro";
import Skills from "src/components/ui/skills.astro";
import Button from "../components/ui/button.svelte";
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main class="container m-4 mx-auto px-4">
    <!-- Hero Section -->
    <section class="py-16 text-center">
      <div class="mx-auto max-w-4xl">
        <h1 class="text-heading mb-6 text-5xl text-shadow-lg/5 md:text-6xl">
          Turning messy data into clear decisions.
        </h1>
        <p
          class="text-text text-shadow-accent dark:text-shadow-primary mb-8 text-xl text-shadow-md/30 md:text-2xl"
        >
          Applied math background with data visualization expertise. <br />
          Based in Philadelphia Area.
        </p>
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <Button
            client:load="svelte"
            link="#featured-projects"
            name="View Work"
          />
        </div>
      </div>
    </section>
    <FeaturedCard type="projects" />

    <!-- About Preview -->
    <section class="py-16">
      <div class="container mx-auto max-w-6xl px-4">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div>
            <h2
              class="font-heading text-heading mb-6 text-3xl text-shadow-sm/10 md:text-4xl"
            >
              Turning Numbers Into Decisions
            </h2>
            <div class="text-text space-y-4">
              <p>
                While studying Applied Mathematics at Ursinus College, I was
                drawn towards data science projects that allowed me to apply my
                statistical and programming skills to real-world problems. 
              </p>
              <p>
                Through that passion, I honed my interest in personal finance by
                building interactive financial calculators and Monte Carlo
                simulations for Ursinus' Financial Services Office, to analyzing
                commercial real estate trends with clear GIS visualizations at
                DataFest Philly 2025, to developing R Shiny dashboards that made
                global economic data intuitive to explore economic events.
              </p>
              <p>
                I am currently looking for data analyst and BI roles where I can
                continue doing what I love most: asking the right questions,
                analyzing data, and creating visualizations that drive clear
                decisions. 
              </p>
            </div>
            <div class="mt-6">
              <a
                href="/about"
                class="text-text hover:text-primary dark:hover:text-accent inline-flex items-center gap-2 font-semibold transition-colors"
              >
                More about me
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Skills/Technologies -->
          <div class="bg-card rounded-4xl p-8">
            <h3
              class="font-heading text-heading mb-6 text-3xl text-shadow-sm/10 md:text-4xl"
            >
              Technologies I Work With
            </h3>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <Skills
                title="Languages"
                items={["Python", "R", "SQL", "Java", "HTML/CSS/JS"]}
              />
              <Skills
                title="Frameworks & Tools"
                items={[
                  "Plotly",
                  "R Shiny",
                  "Astro & Svelte",
                  "Flutter",
                  "Java Swing",
                ]}
              />
              <Skills
                title="Data & Analysis"
                items={[
                  "Data Visualization",
                  "Statistical Analysis",
                  "Tableau",
                  "Database Design",
                ]}
              />
              <Skills
                title="Collaboration"
                items={[
                  "Git/GitHub",
                  "Team Leadership",
                  "Project Management",
                  "Code Review",
                ]}
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
